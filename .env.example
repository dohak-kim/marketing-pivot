# ── Gemini API (필수) ─────────────────────────────────────────────────────────
API_KEY=your_gemini_api_key_here

# ── Serper.dev — Google SERP 실측 데이터 (선택) ───────────────────────────────
# https://serper.dev 에서 발급 | 무료: 2,500건/월
# 설정 시: 검색량/Featured Snippet/PAA/AI Overview 실측값 수집
VITE_SERPER_API_KEY=

# ── Naver Search API (선택) ───────────────────────────────────────────────────
# https://developers.naver.com → 검색 API 앱 등록
VITE_NAVER_CLIENT_ID=
VITE_NAVER_CLIENT_SECRET=

# ── Naver 검색광고 API — 키워드 볼륨 (선택, 사업자 계정 필요) ────────────────────
# https://naver.github.io/searchad-apidoc
# 설정 시: 정확한 PC/모바일 월간 검색량 구간값 수집
VITE_NAVER_AD_API_KEY=
VITE_NAVER_AD_SECRET=
VITE_NAVER_AD_CUSTOMER_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Serper 또는 Naver 중 하나라도 설정되면 RAG 모드 자동 활성화:
#   1. 시드 키워드 생성 (Gemini, 15개)
#   2. 실측 SERP 데이터 수집
#   3. AI는 클러스터링만 수행 (볼륨 발명 없음)
#   4. 실측 Brand Presence 카운팅
#
# 미설정 시: 기존 AI Grounding 모드 (amber 'AI 추정값' 배지 표시)
